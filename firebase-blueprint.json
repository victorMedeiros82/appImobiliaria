{
  "entities": {
    "Contract": {
      "title": "Lease Contract",
      "description": "Represents a rental agreement between a landlord and a tenant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantName": { "type": "string" },
        "landlordName": { "type": "string" },
        "propertyAddress": { "type": "string" },
        "rentValue": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "terminated", "expired"] },
        "readjustmentIndex": { "type": "string", "enum": ["IGPM", "IPCA"] },
        "nextReadjustmentDate": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["tenantName", "rentValue", "startDate", "status", "ownerId"]
    },
    "Payment": {
      "title": "Rent Payment",
      "description": "A payment record for a specific contract installment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contractId": { "type": "string" },
        "value": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "paid", "overdue"] },
        "paymentMethod": { "type": "string", "enum": ["pix", "boleto", "transfer"] },
        "ownerId": { "type": "string" }
      },
      "required": ["contractId", "value", "dueDate", "status", "ownerId"]
    },
    "User": {
      "title": "User Profile",
      "description": "System user profile for landlords or property managers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager"] }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/contracts/{contractId}": {
      "schema": "Contract",
      "description": "Store all rental contracts"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Store all payment installments"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Store user profiles"
    }
  }
}
